MAIL_FROM_NAME="${APP_NAME}"
MAIL_REPLY_TO_ADDRESS="contacto@cybertechnasolutions.com"
MAIL_REPLY_TO_NAME="${APP_NAME}"

CONTACT_EMAIL=contacto@cybertechnasolutions.com

ADMIN_NAME="CyberTechna Owner"
